# Configuración de Variables de Entorno

# API Keys
GOOGLE_API_KEY=tu-api-key-de-gemini
GROQ_API_KEY=tu-api-key-de-groq

# Hugging Face (requerido para UNI y PLIP)
HF_TOKEN=tu-token-huggingface-read

# Neo4j Database
NEO4J_URI=neo4j+s://tu-instancia.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=tu-password-segura

# LangSmith (Opcional - Observabilidad)
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=rag-histologia-v4
